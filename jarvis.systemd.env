# Environment for jarvis.service (systemd EnvironmentFile format)
HOME=/home/ubuntu
GEMINI_CLI_HOME=/home/ubuntu/.gemini
MCP_MODE=http
SERVER_HOST=127.0.0.1
SERVER_PORT=7860
DISPLAY=:1
FILESYSTEM_MCP_ENABLE=false
RECLAIM_UI_AUTOMATION_ENABLE=true
PLAYWRIGHT_MCP_ENABLE=true
RECLAIM_UI_AUTOMATION_HEADLESS=false
RECLAIM_UI_LOGIN_URL=https://app.reclaim.ai/planner?login=1&taskSort=schedule&range=WEEK
RECLAIM_UI_BROWSER_MODE=app
RECLAIM_UI_CHROME_USER_DATA_DIR=/home/ubuntu/.openclaw/state/reclaim-chrome-profile
